{
  "compilerOptions": {
    "moduleResolution": "bundler",
    "allowJs": true,
    "strict": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "isolatedModules": true
  },
  "extends": "expo/tsconfig.base",
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
